---
import { formatDateISO } from '~/lib/format';
import { withBase } from '~/lib/site-config';

interface Props {
  pubDate: Date;
  /** Danh sách tag — chỉ render tối đa 3 để giữ layout compact */
  tags?: readonly string[];
  /** Thời gian đọc ước tính (phút) */
  readingMinutes?: number;
  /** Hiển thị chevron `>` cuối line như design */
  showArrow?: boolean;
  class?: string;
}

const {
  pubDate,
  tags = [],
  readingMinutes,
  showArrow = true,
  class: className = '',
} = Astro.props;

const visibleTags = tags.slice(0, 3);
---

<div
  class:list={[
    'flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-[var(--color-fg-muted)]',
    className,
  ]}
>
  <time datetime={pubDate.toISOString()} class="tabular-nums">
    {formatDateISO(pubDate)}
  </time>

  {visibleTags.length > 0 && <span aria-hidden="true">//</span>}

  {
    // `relative z-10` để tag link nổi lên trên `::after` của stretched-link
    // pattern (xem ArticleCard, blog/index list row). Khi không có
    // stretched-link parent, các style này vô hại.
    visibleTags.map((tag) => (
      <a
        href={withBase(`/tags/${tag}`)}
        class="relative z-10 tracking-wider uppercase hover:text-[var(--color-accent)]"
      >
        {tag}
      </a>
    ))
  }

  {
    (readingMinutes !== undefined || showArrow) && (
      // Right-aligned cluster: gom MIN READ + arrow để chỉ có 1 ml-auto
      // duy nhất push cả cụm về phải, các item bên trong sit cạnh nhau.
      <div class="ml-auto flex items-center gap-2">
        {readingMinutes !== undefined && (
          <span aria-hidden="true">{readingMinutes} MIN READ</span>
        )}
        {showArrow && (
          <span aria-hidden="true" class="text-[var(--color-fg-subtle)]">
            {'>'}
          </span>
        )}
      </div>
    )
  }
</div>
