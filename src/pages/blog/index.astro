---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import PostMeta from '~/components/blog/PostMeta.astro';
import { withBase } from '~/lib/site-config';

const posts = await getCollection('posts', ({ data }) =>
  import.meta.env.PROD ? data.draft !== true : true
);

// Group theo năm — hiển thị timeline archive
const sorted = [...posts].sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const grouped = sorted.reduce<Record<string, typeof sorted>>((acc, post) => {
  const year = String(post.data.pubDate.getUTCFullYear());
  (acc[year] ??= []).push(post);
  return acc;
}, {});

const years = Object.keys(grouped).sort((a, b) => Number(b) - Number(a));
---

<BaseLayout
  title="Journal Archive"
  description="All journal entries — sorted chronologically."
>
  <Container class="pt-12 pb-16">
    <header
      class="border-b border-dashed border-[var(--color-border-strong)] pb-6"
    >
      <p class="terminal-label">FileSystem/Archive</p>
      <h1 class="mt-3 text-3xl font-semibold tracking-tight sm:text-5xl">
        <span class="text-[var(--color-accent)]">//</span> Journal_Archive
      </h1>
      <p class="mt-3 text-[var(--color-fg-muted)]">
        {sorted.length} entries total — grouped by execution year.
      </p>
    </header>

    {
      years.length === 0 ? (
        <p class="mt-8 text-sm text-[var(--color-fg-muted)]">
          Archive trống. Viết bài đầu tiên tại{' '}
          <code class="text-[var(--color-accent)]">src/content/posts/</code>.
        </p>
      ) : (
        years.map((year) => (
          <section class="mt-10">
            <h2 class="text-xl font-semibold tracking-wider text-[var(--color-fg-muted)]">
              {year}
            </h2>
            <ul class="mt-4 divide-y divide-[var(--color-border)] border-y border-[var(--color-border)]">
              {grouped[year]!.map((post) => (
                // Stacked layout: hàng 1 = title + arrow (justify-between),
                // hàng 2 = PostMeta. Stretched-link via `::after` phủ cả <li>
                // để click bất kỳ đâu → post page; tags trong PostMeta vẫn
                // clickable nhờ `relative z-10` (xem PostMeta.astro).
                <li class="group relative flex flex-col gap-1.5 px-3 py-4 transition-colors focus-within:bg-[var(--color-surface)] hover:bg-[var(--color-surface)]">
                  <div class="flex items-baseline justify-between gap-3">
                    <a
                      href={withBase(`/blog/${post.id}`)}
                      class="text-base leading-snug font-medium group-hover:text-[var(--color-accent)] after:absolute after:inset-0 after:content-[''] sm:text-lg"
                    >
                      {post.data.title}
                    </a>
                    <span
                      aria-hidden="true"
                      class="shrink-0 text-[var(--color-fg-subtle)] group-hover:text-[var(--color-accent)]"
                    >
                      {'>'}
                    </span>
                  </div>
                  <PostMeta
                    pubDate={post.data.pubDate}
                    tags={post.data.tags}
                    showArrow={false}
                  />
                </li>
              ))}
            </ul>
          </section>
        ))
      )
    }
  </Container>
</BaseLayout>
