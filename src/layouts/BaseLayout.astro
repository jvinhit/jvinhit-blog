---
import '~/styles/global.css';
import Header from '~/components/layout/Header.astro';
import Footer from '~/components/layout/Footer.astro';
import { SITE, withBase } from '~/lib/site-config';

interface Props {
  title?: string;
  description?: string;
  /** Ảnh OG (absolute URL hoặc path tương đối với site) */
  ogImage?: string;
  /** Disable indexing cho drafts hoặc utility pages */
  noindex?: boolean;
  /** Canonical URL override — mặc định tính từ current path */
  canonical?: string;
}

const {
  title,
  description = SITE.description,
  ogImage,
  noindex = false,
  canonical,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.name}` : SITE.name;
// Astro.url.pathname đã chứa base path, nên khi ghép vào Astro.site
// ta không prepend base thêm lần nữa để tránh double base.
const canonicalURL = canonical
  ? new URL(withBase(canonical), Astro.site).toString()
  : new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = ogImage
  ? new URL(withBase(ogImage), Astro.site).toString()
  : new URL(withBase('/og-default.png'), Astro.site).toString();
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    {/* Sync flag để CSS/script biết môi trường client capabilities trước
     * khi paint đầu tiên — tránh FOUC cho hero typing animation. */}
    <script is:inline>
      (function () {
        var d = document.documentElement;
        d.classList.add('js');
        try {
          if (matchMedia('(prefers-reduced-motion: reduce)').matches) {
            d.classList.add('reduced-motion');
          }
        } catch (_) {
          /* matchMedia not available — leave default */
        }
      })();
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#0a0a0a" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content={SITE.locale} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    {/* RSS */}
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.name} — RSS`}
      href={withBase('/rss.xml')}
    />

    <slot name="head" />
  </head>

  <body class="flex min-h-dvh flex-col">
    <Header pathname={Astro.url.pathname} />

    <main class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
