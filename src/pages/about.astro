---
import { getEntry, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import TerminalBox from '~/components/ui/TerminalBox.astro';
import SkillBar from '~/components/about/SkillBar.astro';
import '~/styles/prose.css';

const entry = await getEntry('about', 'about');
if (!entry) {
  throw new Error(
    'Missing `src/content/about/about.mdx`. Create the file to render /about.'
  );
}
const { Content } = await render(entry);
const { title, role, intent, skills, experience, education, connections } =
  entry.data;
---

<BaseLayout title={title} description={intent}>
  <Container class="pt-12 pb-16">
    {/* Name card */}
    <section class="border-b border-[var(--color-border)] pb-8">
      <p class="terminal-label">System/Interrogate</p>
      <h1
        class="mt-3 text-5xl leading-[1.05] font-semibold tracking-tight sm:text-6xl"
      >
        {title}
      </h1>
      <p
        class="mt-3 text-sm tracking-[0.14em] text-[var(--color-accent)] uppercase sm:text-base"
      >
        {role}
      </p>
      <div class="mt-6">
        <a
          href={`/resume.pdf`}
          class="inline-flex items-center gap-2 rounded-xs border border-[var(--color-accent)] bg-[var(--color-accent)] px-4 py-2 text-xs font-semibold tracking-[0.12em] text-[var(--color-accent-fg)] uppercase transition-colors hover:bg-[var(--color-accent-hover)]"
        >
          Download_Resume.pdf
        </a>
      </div>
    </section>

    <div class="mt-10 grid gap-6 lg:grid-cols-[320px_1fr]">
      {/* Left column — connections */}
      <div class="space-y-6">
        <TerminalBox label="Connection_Nodes">
          <ul class="space-y-3 text-sm">
            {
              connections.map((c) => (
                <li class="flex items-baseline justify-between gap-3 border-b border-dashed border-[var(--color-border)] pb-2 last:border-0">
                  <span class="tracking-wider text-[var(--color-fg-muted)] uppercase">
                    {c.label}
                  </span>
                  {c.href ? (
                    <a
                      href={c.href}
                      class="text-right text-[var(--color-accent)] hover:text-[var(--color-accent-hover)]"
                    >
                      {c.value}
                    </a>
                  ) : (
                    <span class="text-right text-[var(--color-fg)]">
                      {c.value}
                    </span>
                  )}
                </li>
              ))
            }
          </ul>
        </TerminalBox>

        <TerminalBox label="Core_Processes">
          <div class="space-y-3">
            {skills.map((s) => <SkillBar name={s.name} level={s.level} />)}
          </div>
        </TerminalBox>
      </div>

      {/* Right column — intent + experience + education */}
      <div class="space-y-6">
        <TerminalBox label="User_Intent">
          <p class="text-[var(--color-fg)]">{intent}</p>
        </TerminalBox>

        <TerminalBox label="Execution_Log">
          <ol class="space-y-6">
            {
              experience.map((e) => (
                <li class="border-b border-dashed border-[var(--color-border)] pb-5 last:border-0 last:pb-0">
                  <header class="flex items-baseline justify-between gap-3">
                    <h3 class="text-base font-semibold">
                      {e.title}
                      <span class="font-normal text-[var(--color-fg-muted)]">
                        {' @ '}
                        {e.company}
                      </span>
                    </h3>
                    <span class="shrink-0 text-xs tracking-wider text-[var(--color-fg-muted)] uppercase">
                      {e.period}
                    </span>
                  </header>
                  <ul class="mt-2 space-y-1.5 text-sm text-[var(--color-fg)]">
                    {e.bullets.map((b) => (
                      <li class="before:mr-2 before:text-[var(--color-accent)] before:content-['>']">
                        {b}
                      </li>
                    ))}
                  </ul>
                </li>
              ))
            }
          </ol>
        </TerminalBox>

        <TerminalBox label="Training_Data">
          <ol class="space-y-4">
            {
              education.map((e) => (
                <li class="border-b border-dashed border-[var(--color-border)] pb-4 last:border-0 last:pb-0">
                  <header class="flex items-baseline justify-between gap-3">
                    <h3 class="text-base font-semibold">
                      {e.degree}
                      <span class="font-normal text-[var(--color-fg-muted)]">
                        {' @ '}
                        {e.school}
                      </span>
                    </h3>
                    <span class="shrink-0 text-xs tracking-wider text-[var(--color-fg-muted)] uppercase">
                      {e.period}
                    </span>
                  </header>
                  {e.description && (
                    <p class="mt-1 text-sm text-[var(--color-fg-muted)]">
                      {e.description}
                    </p>
                  )}
                </li>
              ))
            }
          </ol>
        </TerminalBox>

        {/* Long-form biography viết trong MDX — render cuối cùng */}
        <TerminalBox label="Additional_Notes">
          <div class="prose-terminal">
            <Content />
          </div>
        </TerminalBox>
      </div>
    </div>
  </Container>
</BaseLayout>
