---
import PostMeta from './PostMeta.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'posts'>;
  /** Số phút đọc ước tính — truyền từ page (tính ở build time) */
  readingMinutes?: number;
  /** Compact variant — ẩn description, dùng cho archive dài */
  compact?: boolean;
}

const { post, readingMinutes, compact = false } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const href = `/blog/${post.id}`;
---

{
  /*
  Pattern: dùng `::after` trên link tiêu đề để biến toàn card thành clickable
  target mà vẫn chỉ có 1 interactive element (tốt cho screen reader + tab order).
  Các element khác trong card là visual-only (aria-hidden, pointer-events-none).
*/
}
<article
  class="group relative border-b border-[var(--color-border)] py-6 transition-colors focus-within:bg-[var(--color-surface)] hover:bg-[var(--color-surface)]"
>
  <div class="px-6">
    <PostMeta
      pubDate={pubDate}
      tags={tags}
      readingMinutes={readingMinutes}
      showArrow
    />

    <h3
      class="mt-3 text-2xl leading-tight font-semibold tracking-tight text-[var(--color-fg)] sm:text-3xl"
    >
      <a
        href={href}
        class="group-hover:text-[var(--color-accent)] after:absolute after:inset-0 after:content-['']"
      >
        {title}
      </a>
    </h3>

    {
      !compact && (
        <p class="mt-2 line-clamp-2 text-sm text-[var(--color-fg-muted)] sm:text-base">
          {description}
        </p>
      )
    }

    <span
      aria-hidden="true"
      class="mt-3 inline-flex items-center gap-1 text-xs font-semibold tracking-[0.12em] text-[var(--color-accent)] uppercase"
    >
      Read_more
      <span>{'>'}</span>
    </span>
  </div>
</article>
