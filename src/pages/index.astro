---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import ArticleCard from '~/components/blog/ArticleCard.astro';
import { SITE, withBase } from '~/lib/site-config';
import { estimateReadingMinutes } from '~/lib/format';

// Số entries hiển thị ban đầu trên homepage. Phần còn lại render kèm
// nhưng `hidden` — client JS sẽ progressive reveal theo từng batch.
const HOMEPAGE_INITIAL = 5;
// Số entries reveal mỗi lần click "Load more". Giữ parity với initial
// để rhythm cuộn của user nhất quán giữa trước và sau click.
const LOAD_MORE_BATCH = 5;

const allPosts = await getCollection('posts', ({ data }) =>
  import.meta.env.PROD ? data.draft !== true : true
);

// Sort newest first
const sortedPosts = [...allPosts].sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

// Tính reading time ở build time cho TẤT CẢ posts — homepage render full
// list rồi dùng client JS để reveal dần (SSG không có API endpoint, làm
// vậy tránh round-trip và giữ trải nghiệm "load more" chỉ trên 1 page).
const postsWithMeta = await Promise.all(
  sortedPosts.map(async (post, index) => {
    const { remarkPluginFrontmatter } = await render(post);
    const readingMinutes =
      (remarkPluginFrontmatter?.readingMinutes as number | undefined) ??
      estimateReadingMinutes(post.body ?? '');
    return {
      post,
      readingMinutes,
      hidden: index >= HOMEPAGE_INITIAL,
    };
  })
);

const totalPosts = sortedPosts.length;
const hasMore = totalPosts > HOMEPAGE_INITIAL;
---

<BaseLayout>
  <Container class="pt-12 pb-16 sm:pt-16">
    {/* Hero */}
    <section class="border-b border-[var(--color-border)] pb-10" data-hero>
      <p class="terminal-label">System/Initialized</p>

      <h1
        class="mt-6 text-4xl leading-[1.1] font-semibold tracking-tight sm:text-6xl md:text-7xl"
        data-typing-target
        data-typing-speed="65"
      >
        Hi, I'm <span class="text-[var(--color-accent)]"
          >{SITE.author.name}</span
        >
      </h1>

      <p
        class="mt-6 max-w-[640px] text-base leading-relaxed text-[var(--color-fg-muted)] sm:text-lg"
        data-typing-target
        data-typing-speed="18"
        data-typing-delay="200"
      >
        {SITE.description}
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={withBase('/blog')}
          class="inline-flex items-center gap-2 rounded-xs border border-[var(--color-border-strong)] bg-transparent px-4 py-2 text-xs font-semibold tracking-[0.12em] text-[var(--color-fg)] uppercase transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
        >
          Run_journal
          <span aria-hidden="true">{'>'}</span>
        </a>
        <a
          href={withBase('/about')}
          class="inline-flex items-center gap-2 rounded-xs border border-transparent px-4 py-2 text-xs font-semibold tracking-[0.12em] text-[var(--color-fg-muted)] uppercase transition-colors hover:text-[var(--color-accent)]"
        >
          View_resume
          <span aria-hidden="true">{'>'}</span>
        </a>
      </div>
    </section>

    <script>
      /**
       * Hero typing animation
       *
       * Design:
       * - Markup chứa text đầy đủ → SEO + no-JS đều thấy nội dung.
       * - CSS hide bằng `visibility:hidden` trước khi script chạy (chỉ khi
       *   `html.js` && không reduced-motion) — giữ layout, tránh flash content.
       * - Script đo `offsetHeight` của mỗi target (được giữ nguyên bởi
       *   `visibility:hidden`) rồi set `min-height` TRƯỚC khi clear content,
       *   đảm bảo không layout shift / CLS trong lúc gõ từng ký tự.
       * - Script snapshot child structure (giữ <span> styling), clear, rồi
       *   gõ từng char. Cursor hiển thị ở block đang gõ; xong thì stay ở cuối.
       * - Skip toàn bộ animation nếu user prefers-reduced-motion.
       */
      type Segment = {
        text: string;
        tag: string | null;
        className: string | null;
      };

      const wait = (ms: number) =>
        new Promise<void>((res) => setTimeout(res, ms));

      function snapshot(el: HTMLElement): Segment[] {
        const segs: Segment[] = [];
        el.childNodes.forEach((node) => {
          if (node.nodeType === Node.TEXT_NODE) {
            segs.push({
              text: node.textContent ?? '',
              tag: null,
              className: null,
            });
          } else if (node.nodeType === Node.ELEMENT_NODE) {
            const e = node as HTMLElement;
            segs.push({
              text: e.textContent ?? '',
              tag: e.tagName.toLowerCase(),
              className: e.className || null,
            });
          }
        });
        return segs;
      }

      function makeCaret(): HTMLSpanElement {
        const c = document.createElement('span');
        c.className = 'typing-caret';
        c.dataset.blink = 'off';
        c.setAttribute('aria-hidden', 'true');
        return c;
      }

      async function typeInto(
        el: HTMLElement,
        segs: Segment[],
        caret: HTMLSpanElement,
        speed: number
      ): Promise<void> {
        el.innerHTML = '';
        el.appendChild(caret);

        for (const seg of segs) {
          if (seg.text.length === 0) continue;

          let container: HTMLElement | Text;
          if (seg.tag) {
            const node = document.createElement(seg.tag);
            if (seg.className) node.className = seg.className;
            container = node;
          } else {
            container = document.createTextNode('');
          }
          // Insert container TRƯỚC caret để caret luôn ở đuôi.
          el.insertBefore(container, caret);

          for (const char of seg.text) {
            if (container instanceof Text) {
              container.data += char;
            } else {
              container.textContent = (container.textContent ?? '') + char;
            }
            await wait(speed);
          }
        }
      }

      async function run() {
        const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduced) return;

        const targets = Array.from(
          document.querySelectorAll<HTMLElement>('[data-typing-target]')
        );
        if (targets.length === 0) return;

        // Đo chiều cao tự nhiên TRƯỚC khi clear — `visibility:hidden` giữ
        // layout nên `offsetHeight` phản ánh đúng kích thước cuối cùng ở
        // viewport hiện tại. Reserve bằng `min-height` để chữ gõ từng ký tự
        // không làm page bị nhảy (zero-CLS).
        const reservedHeights = targets.map((el) => el.offsetHeight);

        // Snapshot TRƯỚC khi clear bất cứ element nào.
        const snapshots = targets.map((el) => snapshot(el));

        // Áp dụng min-height ngay sau khi snapshot — giữ box height ổn định
        // suốt animation. Nếu viewport resize rộng hơn sau này, min-height
        // vẫn an toàn (content lớn hơn → element tự grow theo).
        targets.forEach((el, i) => {
          el.style.minHeight = `${reservedHeights[i]}px`;
        });

        const caret = makeCaret();

        for (let i = 0; i < targets.length; i++) {
          const el = targets[i]!;
          const segs = snapshots[i]!;
          const speed = Number(el.dataset.typingSpeed ?? 30);
          const delay = Number(el.dataset.typingDelay ?? 0);

          if (delay > 0) await wait(delay);

          el.dataset.typingState = 'running';
          await typeInto(el, segs, caret, speed);
          el.dataset.typingState = 'done';
        }

        // Hoàn tất → caret blink ở vị trí cuối block cuối cùng.
        caret.dataset.blink = 'on';
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', run, { once: true });
      } else {
        run();
      }
    </script>

    {/* Latest entries */}
    <section class="mt-10">
      <header class="flex items-baseline justify-between">
        <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">
          <span class="text-[var(--color-accent)]">//</span> Latest_Logs
        </h2>
        <span class="text-xs text-[var(--color-fg-muted)]">
          {totalPosts.toString().padStart(3, '0')} entries
        </span>
      </header>

      {
        postsWithMeta.length === 0 ? (
          <p class="mt-8 text-sm text-[var(--color-fg-muted)]">
            Chưa có bài viết nào. Thêm file MDX vào{' '}
            <code class="text-[var(--color-accent)]">src/content/posts/</code>{' '}
            để bắt đầu.
          </p>
        ) : (
          <ul id="latest-logs-list" class="mt-6" data-posts-list>
            {postsWithMeta.map(({ post, readingMinutes, hidden }) => (
              <li hidden={hidden} data-post-item>
                <ArticleCard post={post} readingMinutes={readingMinutes} />
              </li>
            ))}
          </ul>
        )
      }

      {
        hasMore && (
          <div class="mt-8 flex justify-center" data-load-more-wrapper>
            {/*
              JS-enabled path: button progressive-reveal posts đang ẩn.
              Render-time render full DOM (SSG-friendly) → click chỉ flip
              attribute `hidden`, không có network call.
            */}
            <button
              type="button"
              data-load-more
              data-batch-size={LOAD_MORE_BATCH}
              aria-controls="latest-logs-list"
              class="js-only inline-flex cursor-pointer items-center gap-2 rounded-xs border border-[var(--color-border-strong)] bg-transparent px-5 py-2.5 font-[inherit] text-xs font-semibold tracking-[0.12em] text-[var(--color-fg)] uppercase transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] focus-visible:border-[var(--color-accent)] focus-visible:text-[var(--color-accent)]"
            >
              Load_more_records
              <span aria-hidden="true">{'>'}</span>
            </button>

            {/*
              No-JS fallback: nếu JS không chạy (`html.js` class không
              được set), button bị ẩn bằng CSS và link archive sẽ hiện
              ra → user vẫn truy cập được full danh sách qua /blog.
            */}
            <a
              href={withBase('/blog')}
              class="no-js-only inline-flex items-center gap-2 rounded-xs border border-[var(--color-border-strong)] px-5 py-2.5 text-xs font-semibold tracking-[0.12em] text-[var(--color-fg)] uppercase transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
            >
              Browse_archive
              <span aria-hidden="true">{'>'}</span>
            </a>
          </div>
        )
      }
    </section>

    <style is:global>
      /* Toggle giữa interactive button (JS) và link fallback (no-JS).
         Class `js` được BaseLayout set sync trong <head> → áp dụng trước
         first paint, không có flash. */
      html.js .no-js-only {
        display: none;
      }
      html:not(.js) .js-only {
        display: none;
      }
    </style>

    <script>
      /**
       * Progressive "Load more" trên homepage
       *
       * - SSG nên toàn bộ posts đã có sẵn trong DOM dưới dạng
       *   `<li data-post-item hidden>`. Click button → bóc attribute
       *   `hidden` cho batch tiếp theo, không gọi network.
       * - Sau khi reveal, focus về post đầu tiên của batch → giữ
       *   keyboard/AT user trong context (browser sẽ tự scroll vào view).
       * - Khi không còn item nào hidden → ẩn nguyên wrapper.
       */
      const wrapper = document.querySelector<HTMLElement>(
        '[data-load-more-wrapper]'
      );
      const button = wrapper?.querySelector<HTMLButtonElement>(
        '[data-load-more]'
      );
      const list = document.querySelector<HTMLElement>('[data-posts-list]');

      if (wrapper && button && list) {
        const batchSize = Math.max(
          1,
          Number(button.dataset.batchSize ?? '5') || 5
        );

        button.addEventListener('click', () => {
          const hiddenItems = Array.from(
            list.querySelectorAll<HTMLLIElement>(
              '[data-post-item][hidden]'
            )
          );
          const toReveal = hiddenItems.slice(0, batchSize);
          if (toReveal.length === 0) {
            wrapper.hidden = true;
            return;
          }

          toReveal.forEach((li) => li.removeAttribute('hidden'));

          const firstNewLink =
            toReveal[0]?.querySelector<HTMLAnchorElement>('a[href]');
          firstNewLink?.focus();

          const stillHidden = list.querySelector(
            '[data-post-item][hidden]'
          );
          if (!stillHidden) {
            wrapper.hidden = true;
          }
        });
      }
    </script>
  </Container>
</BaseLayout>
