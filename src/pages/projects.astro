---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
---

<BaseLayout
  title="Projects"
  description="Selected projects & experiments — coming soon."
>
  <Container class="py-16">
    <p class="terminal-label">Directory/Projects</p>
    <h1 class="mt-3 text-3xl font-semibold sm:text-5xl">
      <span class="text-[var(--color-accent)]">//</span> Projects
    </h1>
    <p class="mt-4 max-w-prose text-[var(--color-fg-muted)]">
      Danh sách projects sẽ được hiển thị ở đây. Tạo collection
      <code class="text-[var(--color-accent)]">projects</code> trong
      <code class="text-[var(--color-accent)]">src/content.config.ts</code> và map
      vào page này khi bạn sẵn sàng.
    </p>
  </Container>
</BaseLayout>
