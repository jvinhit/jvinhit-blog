---
import { getCollection, render } from 'astro:content';
import PostLayout from '~/layouts/PostLayout.astro';
import { estimateReadingMinutes } from '~/lib/format';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const posts = await getCollection('posts', ({ data }) =>
    import.meta.env.PROD ? data.draft !== true : true
  );
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}) satisfies GetStaticPaths;

type Props = {
  post: Awaited<ReturnType<typeof getCollection<'posts'>>>[number];
};

const { post } = Astro.props as Props;
const { Content, remarkPluginFrontmatter } = await render(post);

const readingMinutes =
  (remarkPluginFrontmatter?.readingMinutes as number | undefined) ??
  estimateReadingMinutes(post.body ?? '');
---

<PostLayout post={post} readingMinutes={readingMinutes}>
  <Content />
</PostLayout>
