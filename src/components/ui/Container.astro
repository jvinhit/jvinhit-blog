---
// `export interface Props` — Astro vẫn dùng để type-check caller, đồng thời
// `export` đếm là "used" với TS strict → không trigger ts(6196). KHÔNG dùng
// `Astro.props as Props` cast vì gây crash trong `GetPropsType` của compiler
// WASM (compiler scan literal `Astro.props`, không hiểu cast expression).
export interface Props {
  as?: 'div' | 'section' | 'article' | 'main';
  class?: string;
}

const { as: Tag = 'div', class: className = '' } = Astro.props;
---

<Tag class:list={['mx-auto w-full max-w-[1184px] px-6 sm:px-10', className]}>
  <slot />
</Tag>
