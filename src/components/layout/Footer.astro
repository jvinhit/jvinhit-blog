---
import { SITE } from '~/lib/site-config';

const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-[var(--color-border)] py-8">
  <div
    class="mx-auto flex max-w-[1184px] flex-col items-start justify-between gap-4 px-6 text-xs text-[var(--color-fg-muted)] sm:flex-row sm:items-center sm:px-10"
  >
    <p class="tracking-wider uppercase">
      {SITE.handle}
    </p>

    <nav aria-label="Social" class="flex flex-wrap items-center gap-5">
      {
        SITE.socials.map((s) => (
          <a
            href={s.href}
            class="tracking-wider uppercase transition-colors hover:text-[var(--color-accent)]"
            rel={s.rel}
            target="_blank"
          >
            {s.label}
          </a>
        ))
      }
    </nav>

    <p class="text-[var(--color-fg-subtle)]">
      &copy; {year} — BUILT WITH ASTRO
    </p>
  </div>
</footer>
